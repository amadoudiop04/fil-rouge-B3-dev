# ─── Modèle de configuration ───────────────────────────────
# Copie ce fichier en `.env` et remplis les valeurs.
# Ne JAMAIS committer le vrai `.env` (il est ignoré par git).

# API locale
API_PORT=3001

# Base de données MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=b3_esport
DB_USER=root
DB_PASSWORD=

# Clé API Riot Games (gratuite, valide 24h) — https://developer.riotgames.com
RIOT_API_KEY=RGAPI-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
RIOT_REGION=eu

# Token PandaScore (esports temps réel) — https://pandascore.co
# Lu côté SERVEUR uniquement (proxy /esports/*), donc jamais exposé au navigateur.
# `VITE_PANDASCORE_TOKEN` reste accepté pour compatibilité, mais préférez le nom
# sans préfixe VITE_ pour éviter qu'il soit inclus dans le bundle client.
PANDASCORE_TOKEN=ton_token_pandascore_ici
